{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "feature",
        "product-tour",
        "story-demo"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "tagline": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "narrative": {
      "type": "string",
      "minLength": 1
    },
    "promo": {
      "type": "object",
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "highlight": {
          "type": "boolean"
        }
      },
      "required": [
        "order"
      ],
      "additionalProperties": false
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "demo": {
      "type": "object",
      "properties": {
        "renderer": {
          "type": "string",
          "enum": [
            "playwright",
            "binary"
          ]
        },
        "spec": {
          "type": "string",
          "minLength": 1
        },
        "artifactDir": {
          "type": "string",
          "minLength": 1
        },
        "videoBase": {
          "type": "string",
          "minLength": 1
        },
        "posterStep": {
          "type": "string",
          "minLength": 1
        },
        "story": {
          "type": "string",
          "minLength": 1
        },
        "flow": {
          "type": "string",
          "minLength": 1
        },
        "hostCassette": {
          "type": "string",
          "minLength": 1
        },
        "external": {
          "type": "boolean"
        },
        "profiles": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "desktop",
              "tablet",
              "mobile"
            ]
          }
        }
      },
      "required": [
        "artifactDir",
        "videoBase"
      ],
      "additionalProperties": false
    },
    "sections": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "clips": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string",
                  "minLength": 1
                },
                "chapters": {
                  "type": "array",
                  "prefixItems": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "string",
                      "minLength": 1
                    }
                  ]
                }
              },
              "required": [
                "source"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "title",
          "body",
          "clips"
        ],
        "additionalProperties": false
      }
    },
    "tour": {
      "type": "object",
      "properties": {
        "export": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "steps": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "route": {
                "type": "string",
                "enum": [
                  "home",
                  "interactive",
                  "any"
                ]
              },
              "target": {
                "type": "string",
                "minLength": 1
              },
              "targetText": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "placement": {
                "type": "string",
                "enum": [
                  "top",
                  "bottom",
                  "left",
                  "right",
                  "center"
                ]
              },
              "kind": {
                "type": "string",
                "enum": [
                  "explain",
                  "action"
                ]
              },
              "advance": {
                "type": "string",
                "enum": [
                  "next",
                  "click-target",
                  "route-match"
                ]
              },
              "advanceRoute": {
                "type": "string",
                "enum": [
                  "home",
                  "interactive",
                  "any"
                ]
              },
              "waitForTarget": {
                "type": "string",
                "minLength": 1
              },
              "dwellMs": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "drive": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "type-and-send",
                        "click-intent",
                        "wait-state",
                        "reveal-turn",
                        "dwell-ms"
                      ]
                    },
                    "text": {
                      "type": "string",
                      "minLength": 1
                    },
                    "intent": {
                      "type": "string",
                      "minLength": 1
                    },
                    "state": {
                      "type": "string",
                      "minLength": 1
                    },
                    "ms": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "type"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "id",
              "route",
              "title",
              "body",
              "placement",
              "kind",
              "advance"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "export",
        "steps"
      ],
      "additionalProperties": false
    },
    "qa": {
      "type": "object",
      "properties": {
        "scenarios": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "steps": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "id",
              "title",
              "required",
              "steps"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "scenarios"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "kind",
    "title",
    "tagline",
    "summary"
  ],
  "additionalProperties": false
}
