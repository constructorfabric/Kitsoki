<!doctype html>
<!--
  Starter static mockup page for a tour scenario (pongo2 template).
  The author task copies/specialises one of these per scenario under the
  workspace. Give interactive regions stable id / data-testid so a tour step
  can `target` them — that id becomes the chapter sidecar's source_ref.step_id.
-->
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ feature|default:"Feature mockup" }} — {{ scenario|default:"scenario" }}</title>
  <style>
    :root { --bg:#0f1117; --fg:#e6e8ee; --accent:#4f8cff; --muted:#9aa3b2; }
    * { box-sizing: border-box; }
    body { margin:0; font:16px/1.5 system-ui, sans-serif; background:var(--bg); color:var(--fg); }
    header { padding:16px 24px; border-bottom:1px solid #232838; display:flex; gap:12px; align-items:center; }
    header .logo { width:28px; height:28px; border-radius:6px; background:var(--accent); }
    main { padding:32px 24px; max-width:960px; margin:0 auto; }
    h1 { font-size:22px; margin:0 0 8px; }
    .panel { border:1px solid #232838; border-radius:10px; padding:20px; margin:20px 0; background:#141826; }
    .muted { color:var(--muted); }
    button { background:var(--accent); color:#fff; border:0; border-radius:8px; padding:10px 16px; font:inherit; cursor:pointer; }
  </style>
</head>
<body>
  <header>
    <div class="logo" data-testid="brand-logo"></div>
    <strong>{{ feature|default:"Feature" }}</strong>
  </header>
  <main>
    <h1 data-testid="scenario-title">{{ scenario|default:"Scenario" }}</h1>
    <p class="muted">{{ summary|default:"What this scenario demonstrates." }}</p>

    <section class="panel" data-testid="primary-region">
      <!-- Author the feature's primary surface here. -->
      <p>{{ body|default:"Primary surface for this scenario." }}</p>
      <button data-testid="primary-action">{{ cta|default:"Continue" }}</button>
    </section>
  </main>
</body>
</html>
