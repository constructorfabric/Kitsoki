{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "locale", "target", "files_changed"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["en", "th", "ja"]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
