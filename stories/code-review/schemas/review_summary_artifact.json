{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "review_summary_artifact",
  "description": "Review summary the reviewer produces after reading the diff. Captures impressions, concerns, nits.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown"],
  "properties": {
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 20 },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "line":        { "type": ["integer", "string"] },
          "description": { "type": "string" },
          "severity":    { "type": "string", "enum": ["blocker", "major", "minor"] }
        },
        "additionalProperties": true
      }
    },
    "nits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file":        { "type": "string" },
          "line":        { "type": ["integer", "string"] },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "overall_impression": { "type": "string", "enum": ["lgtm", "minor_concerns", "needs_rework", "block"] },
    "confidence":         { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "additionalProperties": true
}
