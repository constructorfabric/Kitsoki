{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "feature_artifact",
  "description": "One feature artifact per phase from the decomposition. Walked N times for N phases. Produced by feature_executing via iface.artifact.create (cpt generate --kind feature --parent <PRD>).",
  "type":    "object",
  "required": ["id", "kind", "summary_title", "summary_markdown"],
  "properties": {
    "id":               { "type": "string", "minLength": 2 },
    "kind":             { "type": "string", "enum": ["feature"] },
    "path":             { "type": "string" },
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40 },
    "title":            { "type": "string" },
    "slug":             { "type": "string" },
    "parent_id":        { "type": "string" },
    "phase":            { "type": "integer", "minimum": 0 },
    "pr_title":         { "type": "string" },
    "pr_body":          { "type": "string" }
  },
  "additionalProperties": true
}
