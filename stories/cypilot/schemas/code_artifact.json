{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "code_artifact",
  "description": "Implementation result for a feature. Produced by code_executing via iface.artifact.create (cpt generate --kind code --parent <feature>) plus iface.ci.run_tests. The PR title / body fields are projected into pr_title / pr_body for the pr-refinement handoff.",
  "type":    "object",
  "required": ["summary_title", "summary_markdown", "pr_title", "pr_body"],
  "properties": {
    "id":               { "type": "string" },
    "kind":             { "type": "string", "enum": ["code"] },
    "path":             { "type": "string" },
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40 },
    "pr_title":         { "type": "string", "minLength": 4 },
    "pr_body":          { "type": "string", "minLength": 10 },
    "files_changed":    { "type": "array", "items": { "type": "string" } },
    "tests_passed":     { "type": "integer", "minimum": 0 },
    "tests_failed":     { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
