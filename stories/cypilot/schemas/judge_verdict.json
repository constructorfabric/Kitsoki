{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "judge_verdict",
  "description": "Canonical verdict shape — verbatim copy of stories/bugfix/schemas/judge_verdict.json so cypilot can load standalone without a bugfix dependency.",
  "type":    "object",
  "required": ["verdict", "intent", "reason", "confidence"],
  "properties": {
    "verdict":    { "type": "string", "enum": ["pass", "fail", "uncertain"] },
    "intent":     { "type": "string", "enum": ["accept", "refine", "restart_from", "quit", "uncertain"] },
    "reason":     { "type": "string", "minLength": 4 },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  },
  "additionalProperties": false
}
