{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":   "prd_artifact",
  "description": "Product Requirements Document. Produced by prd_executing via iface.artifact.create (cpt generate --kind prd), judged at prd_awaiting_reply via iface.artifact.validate (cpt analyze).",
  "type":    "object",
  "required": ["id", "kind", "summary_title", "summary_markdown"],
  "properties": {
    "id":               { "type": "string", "minLength": 2 },
    "kind":             { "type": "string", "enum": ["prd"] },
    "path":             { "type": "string" },
    "summary_title":    { "type": "string", "minLength": 4 },
    "summary_markdown": { "type": "string", "minLength": 40 },
    "title":            { "type": "string" },
    "slug":             { "type": "string" },
    "parent_id":        { "type": "string" }
  },
  "additionalProperties": true
}
