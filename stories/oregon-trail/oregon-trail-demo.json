        {
          "turn": 3,
          "room": "trail_guide.active_new",
          "user": null,
          "flow": [
            { "kind": "assistant", "tag": "agent · converse", "model": "claude-sonnet-4-6", "text": "The Kansas runs high in April — depth up to 1.6× normal. Ford only if shallow. Otherwise caulk and float; the oxen keep their footing. Spare axle in hand before you commit." }
          ],
          "effects": [
            { "kind": "tool", "name": "host.chat.suggest_title", "ok": true, "detail": "auto-title: wagon fording advice", "duration": "8ms" },
            { "kind": "world", "changes": [
              { "key": "wagon_chat_turns", "before": "0", "after": "1" },
              { "key": "wagon_chat_title", "before": "∅", "after": "wagon fording advice" }
            ]},
            { "kind": "transition", "from": "trail_guide.active_new", "to": "trail_guide.active", "intent": "ask_question" }
          ]
        }
      ],
      "cardHold": 150,
      "hold": 210,
      "narration": "At any checkpoint, consult the wagon master. A mode:conversational room backed by host.agent.converse — the same chat thread persists across the whole journey."
