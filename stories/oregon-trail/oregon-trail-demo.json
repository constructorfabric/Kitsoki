    {
      "type": "transcript",
      "app": "oregon-trail",
      "session": "intro wizard",
      "totals": { "turns": 3, "haveTokens": false, "haveCost": false },
      "cards": [
        {
          "turn": 1,
          "room": "intro_profession",
          "user": { "text": "banker", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "pick_profession · profession:banker" }
          ],
          "effects": [
            { "kind": "world", "changes": [
              { "key": "profession", "before": "∅", "after": "banker" },
              { "key": "money",      "before": "∅", "after": "$1,600" }
            ]},
            { "kind": "transition", "from": "intro_profession", "to": "intro_month", "intent": "pick_profession" }
          ]
        },
        {
          "turn": 2,
          "room": "intro_month",
          "user": { "text": "depart in may", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "pick_month · month:may" }
          ],
          "effects": [
            { "kind": "world", "changes": [
              { "key": "month", "before": "∅", "after": "may" }
            ]},
            { "kind": "transition", "from": "intro_month", "to": "intro_party_names", "intent": "pick_month" }
          ]
        },
        {
          "turn": 3,
          "room": "intro_party_names",
          "user": { "text": "name the party after the Beatles", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "generate_names · theme:Beatles" }
          ],
          "effects": [
            { "kind": "tool", "name": "host.agent.decide", "ok": true, "detail": "party_namer · schema:party_names.json", "duration": "1.2s" },
            { "kind": "world", "changes": [
              { "key": "party_names", "before": "∅", "after": "John,Paul,George,Ringo,Pete" }
            ]},
            { "kind": "transition", "from": "intro_party_names", "to": "intro_party_names", "intent": "generate_names", "self": true }
          ]
        }
      ],
      "cardHold": 150,
      "hold": 210,
      "narration": "Casual phrasing, typed intents. 'Banker' fires pick_profession. 'Name the party after the Beatles' calls agent.decide — schema-typed JSON for five names."
    },

    {
      "type": "trace",
      "title": "Semantic routing at the general store",
      "turns": [
        {
          "user": "i want 10 oxen, 2000 lbs food, 30 boxes bullets, 4 wheels",
