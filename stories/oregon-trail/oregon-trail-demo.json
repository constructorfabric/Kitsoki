            { "name": "LLM",     "result": "HIT", "ms": 340 }
          ],
          "intent": "propose_purchase"
        },
        {
          "user": "leave",
          "layers": [
            { "name": "synonym", "result": "HIT" }
          ],
          "intent": "leave_store",
          "no_llm": true
        }
      ],
      "caption": "Freeform basket orders need LLM slot extraction. Short commands hit synonyms — no LLM call.",
      "hold": 240,
      "narration": "Full basket orders need LLM slot extraction. Short commands hit synonyms — no agent call."
    },

    {
      "type": "transcript",
      "app": "oregon-trail",
      "session": "general store",
      "totals": { "turns": 3, "haveTokens": false, "haveCost": false },
      "cards": [
        {
          "turn": 1,
          "room": "general_store.idle",
          "user": { "text": "i want 10 oxen, 2000 lbs food, 30 boxes bullets, 4 wheels, 2 axles, 2 tongues", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "propose_purchase · 7 slots extracted" }
          ],
          "effects": [
            { "kind": "world", "changes": [
              { "key": "proposal_items",      "before": "∅", "after": "10 oxen, 2000 lbs food…" },
              { "key": "proposal_total_cost", "before": "∅", "after": "$788" }
            ]},
            { "kind": "transition", "from": "general_store.idle", "to": "general_store.reviewing", "intent": "propose_purchase" }
          ]
        },
        {
          "turn": 2,
          "room": "general_store.reviewing",
          "user": { "text": "actually give me 12 oxen", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "refine_purchase · oxen:12" }
          ],
          "effects": [
            { "kind": "world", "changes": [
              { "key": "proposal_oxen",       "before": "10",   "after": "12" },
              { "key": "proposal_total_cost", "before": "$788", "after": "$868" },
              { "key": "proposal_refine_count","before": "0",   "after": "1" }
            ]},
            { "kind": "transition", "from": "general_store.reviewing", "to": "general_store.reviewing", "intent": "refine_purchase", "self": true }
          ]
        },
        {
          "turn": 3,
          "room": "general_store.reviewing",
          "user": { "text": "accept_purchase", "direct": false },
          "flow": [
            { "kind": "decision", "verb": "route", "outcome": "accept_purchase" }
          ],
          "effects": [
            { "kind": "world", "changes": [
              { "key": "money",    "before": "$1,600", "after": "$732" },
              { "key": "oxen",     "before": "0",      "after": "12" },
              { "key": "food_lbs", "before": "0",      "after": "2000" }
            ], "more": 4 },
            { "kind": "transition", "from": "general_store.reviewing", "to": "general_store.done", "intent": "accept_purchase" }
          ]
        }
      ],
      "cardHold": 150,
      "hold": 210,
      "narration": "Draft, refine, accept — all declarative. Each refinement is a world write; the same view template re-renders the updated proposal."
    },

