: 0px; }.ci-x { color: rgb(209, 36, 47); font-weight: 700; }.ci-ok { color: rgb(26, 127, 55); font-weight: 700; }.ci-name { font-weight: 600; }.conflict-banner { border: 1px solid rgb(212, 167, 44); background: rgb(255, 248, 197); border-radius: 6px; padding: 12px 16px; margin: 4px 0px 14px; font-size: 13px; display: flex; align-items: center; gap: 8px; }.conflict-banner .warn { color: rgb(154, 103, 0); font-weight: 700; }.resolved-chip { display: inline-flex; align-items: center; border-radius: 2em; padding: 2px 10px; font-size: 12px; font-weight: 600; background: rgb(130, 80, 223); color: rgb(255, 255, 255); margin-left: 8px; }.comment.resolved { opacity: 0.62; }.comment.resolved .cbody p { text-decoration: line-through rgb(140, 149, 159); }.edited { color: rgb(89, 99, 110); font-size: 12px; font-style: italic; }"},"childNodes":[{"type":3,"textContent":"","id":13}],"id":12},{"type":3,"textContent":"\n","id":14},{"type":2,"tagName":"script","attributes":{"type":"text/javascript"},"childNodes":[{"type":3,"textContent":"SCRIPT_PLACEHOLDER","id":16}],"id":15}],"id":5},{"type":3,"textContent":"\n","id":17},{"type":2,"tagName":"body","attributes":{},"childNodes":[{"type":3,"textContent":"\n  ","id":19},{"type":2,"tagName":"div","attributes":{"class":"ghhead"},"childNodes":[{"type":3,"textContent":"\n    ","id":21},{"type":2,"tagName":"svg","attributes":{"class":"mark","viewBox":"0 0 16 16","fill":"#1f2328","aria-hidden":"true"},"childNodes":[{"type":2,"tagName":"path","attributes":{"d":"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.0