    {
      "type": "narrative",
      "eyebrow": "Semantic routing",
      "body": "Three layers route most turns without the LLM.",
      "lede": "Synonyms catch verbatim aliases. Slot templates catch common shapes. The LLM is called only when both layers miss — and 78% of turns don't reach it.",
      "hold": 195,
      "narration": "Three semantic layers route most turns. Synonyms first, slot templates next, the LLM only as fallback."
    },
    {
      "type": "trace",
      "title": "Deterministic first",
      "turns": [
        {
          "user": "kick off the next bug",
          "layers": [
            {
              "name": "synonym",
              "result": "MISS"
            },
            {
              "name": "slot",
              "result": "MISS"
            },
            {
              "name": "LLM",
              "result": "HIT",
              "ms": 240
            }
          ],
          "intent": "pickup_bug"
        },
        {
          "user": "review",
          "layers": [
            {
              "name": "synonym",
              "result": "HIT"
            }
          ],
          "intent": "review_bug",
          "no_llm": true
        }
      ],
      "caption": "Synonyms and slot templates handle the common cases. The LLM is only called when they miss.",
      "hold": 210,
      "narration": "The first turn misses both deterministic layers, so kitsoki calls the LLM. The second turn hits a synonym — no LLM needed."
    },
    {
      "type": "narrative",
      "eyebrow": "The dev loop",
      "body": "Author locally. Replay. Deploy.",
      "lede": "Edit the YAML. Test without an LLM call. Attach to GitHub Issues or Jira with one config change.",
      "hold": 165,
      "narration": "Author locally. Replay. Deploy. Switch to GitHub or Jira."
    },
