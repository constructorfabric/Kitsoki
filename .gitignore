# Compiled binary
/kitsoki
/fromflow
/fromsession
# scratch binaries (inline comments don't work in .gitignore — keep them separate)
/.kitsoki-flows

# Ephemeral render artifacts (viewable over VS Code remote tunnel)
/.artifacts/

# Test binaries and coverage
*.test
coverage.out
coverage.html

# Go workspace
/vendor/

# Python bytecode cache (session-mining tooling)
__pycache__/
*.pyc

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Claude Code local state
.claude/

# Git worktrees (local checkouts of feature branches)
.worktrees/

# Per-repo session traces auto-dropped by `kitsoki run` into the nearest
# .kitsoki/ folder. The rest of `.kitsoki/` is reserved for local state
# we may want to keep around; only the auto-traces are guaranteed
# throwaway.
.kitsoki/sessions/

# Local session summaries (per-checkout, not committed)
.context/

# Build output
dist/

# Generated visualisations from `kitsoki viz`
*-viz.dot
*-viz.mmd

# Pellicule (video pipeline) — node deps and generated frames/output
tools/pellicule/node_modules/
tools/pellicule/*.mp4
tools/pellicule/frames/

# Proposal-authoring per-session workspace (dev-story `idea` flow):
# scratch dir holding the numbered check artifacts (001-brief …
# 004-references). The proposal.md is published into docs/proposals/ on
# accept; the checks stay here as the per-proposal record.
docs/proposals/.workspace/

# Run-status SPA — single-file HTML artifacts (built by `kitsoki
# export-status … -o *.html` and by the Playwright artifact suite).
.artifacts/
tools/runstatus/test-results/
tools/runstatus/playwright-report/
tools/runstatus/node_modules/

# Embedded runstatus SPA bundle: generated by `make build` (pnpm build),
# staged into the embed dir. Keep only the .gitkeep placeholder so the
# //go:embed pattern matches on a fresh checkout.
internal/runstatus/web/assets/index.html

# Local-model oracle cache: the llama-server binary and *.gguf weights fetched
# on first use (or pre-warmed via `make fetch-models` / `fetch-llama-server`).
# The real cache lives at ~/.cache/kitsoki (or $KITSOKI_CACHE_DIR); this in-repo
# dir is only a documented prewarm target. Never commit binaries/weights — keep
# only the .gitkeep placeholder.
internal/oracle/server/cache/*
!internal/oracle/server/cache/.gitkeep
bin/
