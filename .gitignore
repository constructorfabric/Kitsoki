# Compiled binary
/kitsoki
/fromflow
/fromsession
# scratch binaries (inline comments don't work in .gitignore — keep them separate)
/.kitsoki-flows

# Ephemeral render artifacts (viewable over VS Code remote tunnel)
/.artifacts/

# Test binaries and coverage
*.test
coverage.out
coverage.html
.cache/

# Go workspace
/vendor/

# Python bytecode cache (session-mining tooling)
__pycache__/
*.pyc

# macOS
.DS_Store

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Claude Code local state
.claude/

# Git worktrees (local checkouts of feature branches)
.worktrees/

# Per-developer harness-profile overrides, deep-merged on top of the
# checked-in .kitsoki.yaml (local wins). Holds secret-bearing / machine-specific
# profiles; start from .kitsoki.local.yaml.example. See webconfig.LocalConfigPath.
.kitsoki.local.yaml

# Per-repo session traces auto-dropped by `kitsoki run` into the nearest
# .kitsoki/ folder. The rest of `.kitsoki/` is reserved for local state
# we may want to keep around; only the auto-traces are guaranteed
# throwaway.
.kitsoki/sessions/

# Local session summaries (per-checkout, not committed)
.context/

# Build output
dist/

# Generated visualisations from `kitsoki viz`
*-viz.dot
*-viz.mmd

# Pellicule (video pipeline) — node deps and generated frames/output
tools/pellicule/node_modules/
tools/pellicule/*.mp4
tools/pellicule/frames/

# Proposal-authoring per-session workspace (dev-story `idea` flow):
# scratch dir holding the numbered check artifacts (001-brief …
# 004-references). The proposal.md is published into docs/proposals/ on
# accept; the checks stay here as the per-proposal record.
docs/proposals/.workspace/

# Run-status SPA — single-file HTML artifacts (built by `kitsoki
# export-status … -o *.html` and by the Playwright artifact suite).
.artifacts/
tools/runstatus/test-results/
tools/runstatus/playwright-report/
tools/runstatus/node_modules/

# Embedded runstatus SPA bundle: generated by `make build` (pnpm build),
# staged into the embed dir. Keep only the .gitkeep placeholder so the
# //go:embed pattern matches on a fresh checkout.
internal/runstatus/web/assets/index.html

# Local-model oracle cache: the llama-server binary and *.gguf weights fetched
# on first use (or pre-warmed via `make fetch-models` / `fetch-llama-server`).
# The real cache lives at ~/.cache/kitsoki (or $KITSOKI_CACHE_DIR); this in-repo
# dir is only a documented prewarm target. Never commit binaries/weights — keep
# only the .gitkeep placeholder.
internal/oracle/server/cache/*
!internal/oracle/server/cache/.gitkeep
bin/

# Promo site / help docs (tools/site) — staged docs/media and build outputs are
# derived (from docs/, features/, and .artifacts/ recordings); never committed.
tools/site/node_modules/
tools/site/.vitepress/gen/
tools/site/.vitepress/dist/
tools/site/.vitepress/dist-embedded/
tools/site/.vitepress/cache/
tools/site/src/guide/
tools/site/src/public/media/

# Embedded help-docs staging (make site-embed); only the .gitkeep placeholder
# is committed so //go:embed matches on a fresh checkout.
internal/helpdocs/assets/*
!internal/helpdocs/assets/.gitkeep

# Embedded base-story library staging (make embed-stories): the top-level
# stories/ tree is mirrored here so //go:embed can ship it. Only the .gitkeep
# placeholder is committed so //go:embed matches on a fresh checkout.
internal/basestories/stories/*
!internal/basestories/stories/.gitkeep
internal/basestories/.embed-stamp

# .agents/{skills,agents} staged here so //go:embed can ship the agent toolkit.
# Only the .gitkeep placeholder is committed so //go:embed matches on a fresh
# checkout (see internal/baseskills).
internal/baseskills/assets/*
!internal/baseskills/assets/.gitkeep
internal/baseskills/.embed-stamp

# Slidey decks: commit only the .json spec — the .html is a deterministic
# render (VS Code extension / `slidey bundle`), no value in checking it in.
*.slidey.html
docs/decks/*.html

# generated by bench.py summarize (durable verdicts live in results/cells/)
tools/bugfix-bakeoff/external/results/summary.json

.pnpm-store
