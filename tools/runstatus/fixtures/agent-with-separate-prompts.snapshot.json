  "mermaid": {
    "source": "%% Bug-fix pipeline\n%% kitsoki viz --flowchart --detail states\nflowchart LR\n\n  Start([\"<b>Start</b>\"]):::input\n\n  subgraph SG___exit__abandoned[\"<b>__exit__abandoned</b> \u2014 Exit: abandoned\"]\n    direction LR\n    ST___exit__abandoned[/\"__exit__abandoned\"/]:::room\n  end\n\n  subgraph SG___exit__done[\"<b>__exit__done</b> \u2014 Exit: done\"]\n    direction LR\n    ST___exit__done[/\"__exit__done\"/]:::room\n  end\n\n  subgraph SG___exit__pick_ticket[\"<b>__exit__pick_ticket</b> \u2014 Exit: pick_ticket\"]\n    direction LR\n    ST___exit__pick_ticket[/\"__exit__pick_ticket\"/]:::room\n  end\n\n  subgraph SG_done[\"<b>phase 3 \u00b7 done</b> \u2014 Build the run's close-out artifact; accept to hand off to pr-refinement.\"]\n    direction LR\n    ST_done[/\"done\"/]:::room\n  end\n\n  subgraph SG_idle[\"<b>phase 0 \u00b7 idle</b> \u2014 Bug-fix pipeline parked. Waiting for start.\"]\n    direction LR\n    ST_idle[/\"idle\"/]:::room\n  end\n\n  subgraph SG_implementing[\"<b>phase 6 \u00b7 implementing</b> \u2014 Apply the proposed fix to the workspace; advance to testing.\"]\n    direction LR\n    ST_implementing[/\"implementing\"/]:::room\n  end\n\n  subgraph SG_proposing[\"<b>phase 4 \u00b7 proposing</b> \u2014 Draft the fix proposal; review and advance to implementing.\"]\n    direction LR\n    ST_proposing[/\"proposing\"/]:::room\n  end\n\n  subgraph SG_reproducing[\"<b>phase 1 \u00b7 reproducing</b> \u2014 Reproduce the bug; produce the reproduction artifact for review.\"]\n    direction LR\n    ST_reproducing[/\"reproducing\"/]:::room\n  end\n\n  subgraph SG_reviewing[\"<b>phase 7 \u00b7 reviewing</b> \u2014 Self-review the diff (code + security); advance to validating.\"]\n    direction LR\n    ST_reviewing[/\"reviewing\"/]:::room\n  end\n\n  subgraph SG_testing[\"<b>phase 5 \u00b7 testing</b> \u2014 Run + review tests for the applied fix; advance to reviewing (or done in quick mode).\"]\n    direction LR\n    ST_testing[/\"testing\"/]:::room\n  end\n\n  subgraph SG_validating[\"<b>phase 2 \u00b7 validating</b> \u2014 Validate the fix against the full environment; advance to done.\"]\n    direction LR\n    ST_validating[/\"validating\"/]:::room\n  end\n\n  Start --> ST_idle\n\n  ST_done -- \"quit\" --> ST___exit__abandoned\n  ST_done -- \"refine [world.done_cycle &gt;= \u2026]\" --> ST___exit__abandoned\n  ST_done -- \"accept\" --> ST___exit__done\n  ST_done -- \"look\" --> ST_done\n  ST_done -- \"refine\" --> ST_done\n  ST_done -- \"restart_from [slots.stage == 'impl\u2026]\" --> ST_implementing\n  ST_done -- \"restart_from [slots.stage == 'prop\u2026]\" --> ST_proposing\n  ST_done -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_done -- \"restart_from [slots.stage == 'test\u2026]\" --> ST_testing\n  ST_done -- \"restart_from\" --> ST_validating\n  ST_done -- \"restart_from [slots.stage == 'vali\u2026]\" --> ST_validating\n  ST_idle -- \"quit\" --> ST___exit__abandoned\n  ST_idle -- \"change_ticket\" --> ST___exit__pick_ticket\n  ST_idle -- \"look\" --> ST_idle\n  ST_idle -- \"full_pipeline\" --> ST_reproducing\n  ST_idle -- \"quick_fix\" --> ST_reproducing\n  ST_idle -- \"start\" --> ST_reproducing\n  ST_idle -- \"skip_to_pr\" --> ST_validating\n  ST_implementing -- \"quit\" --> ST___exit__abandoned\n  ST_implementing -- \"look\" --> ST_implementing\n  ST_implementing -- \"restart_from\" --> ST_proposing\n  ST_implementing -- \"restart_from [slots.stage == 'prop\u2026]\" --> ST_proposing\n  ST_implementing -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_implementing -- \"accept\" --> ST_testing\n  ST_proposing -- \"jump_to\" --> ST___exit__abandoned\n  ST_proposing -- \"quit\" --> ST___exit__abandoned\n  ST_proposing -- \"refine [world.proposing_cycl\u2026]\" --> ST___exit__abandoned\n  ST_proposing -- \"jump_to [slots.stage == 'done\u2026]\" --> ST_done\n  ST_proposing -- \"accept\" --> ST_implementing\n  ST_proposing -- \"look\" --> ST_proposing\n  ST_proposing -- \"refine\" --> ST_proposing\n  ST_proposing -- \"restart_from\" --> ST_proposing\n  ST_proposing -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_proposing -- \"jump_to [slots.stage == 'test\u2026]\" --> ST_testing\n  ST_proposing -- \"jump_to [slots.stage == 'vali\u2026]\" --> ST_validating\n  ST_reproducing -- \"jump_to\" --> ST___exit__abandoned\n  ST_reproducing -- \"quit\" --> ST___exit__abandoned\n  ST_reproducing -- \"refine [world.reproducing_cy\u2026]\" --> ST___exit__abandoned\n  ST_reproducing -- \"jump_to [slots.stage == 'done\u2026]\" --> ST_done\n  ST_reproducing -- \"accept\" --> ST_proposing\n  ST_reproducing -- \"full_pipeline\" --> ST_reproducing\n  ST_reproducing -- \"look\" --> ST_reproducing\n  ST_reproducing -- \"quick_fix\" --> ST_reproducing\n  ST_reproducing -- \"refine\" --> ST_reproducing\n  ST_reproducing -- \"restart_from\" --> ST_reproducing\n  ST_reproducing -- \"jump_to [slots.stage == 'test\u2026]\" --> ST_testing\n  ST_reproducing -- \"jump_to [slots.stage == 'vali\u2026]\" --> ST_validating\n  ST_reproducing -- \"skip_to_pr\" --> ST_validating\n  ST_reviewing -- \"quit\" --> ST___exit__abandoned\n  ST_reviewing -- \"restart_from [slots.stage == 'impl\u2026]\" --> ST_implementing\n  ST_reviewing -- \"restart_from\" --> ST_proposing\n  ST_reviewing -- \"restart_from [slots.stage == 'prop\u2026]\" --> ST_proposing\n  ST_reviewing -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_reviewing -- \"look\" --> ST_reviewing\n  ST_reviewing -- \"restart_from [slots.stage == 'test\u2026]\" --> ST_testing\n  ST_reviewing -- \"accept\" --> ST_validating\n  ST_testing -- \"accept [(world.implement_rev\u2026]\" --> ST___exit__abandoned\n  ST_testing -- \"jump_to\" --> ST___exit__abandoned\n  ST_testing -- \"quit\" --> ST___exit__abandoned\n  ST_testing -- \"refine [world.testing_cycle \u2026]\" --> ST___exit__abandoned\n  ST_testing -- \"accept [world.bugfix_mode ==\u2026]\" --> ST_done\n  ST_testing -- \"jump_to [slots.stage == 'done\u2026]\" --> ST_done\n  ST_testing -- \"accept [world.implement_revi\u2026]\" --> ST_implementing\n  ST_testing -- \"restart_from [slots.stage == 'impl\u2026]\" --> ST_implementing\n  ST_testing -- \"restart_from\" --> ST_proposing\n  ST_testing -- \"restart_from [slots.stage == 'prop\u2026]\" --> ST_proposing\n  ST_testing -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_testing -- \"accept\" --> ST_reviewing\n  ST_testing -- \"look\" --> ST_testing\n  ST_testing -- \"refine\" --> ST_testing\n  ST_testing -- \"jump_to [slots.stage == 'vali\u2026]\" --> ST_validating\n  ST_validating -- \"accept [world.validate_artif\u2026]\" --> ST___exit__abandoned\n  ST_validating -- \"jump_to\" --> ST___exit__abandoned\n  ST_validating -- \"quit\" --> ST___exit__abandoned\n  ST_validating -- \"refine [world.validating_cyc\u2026]\" --> ST___exit__abandoned\n  ST_validating -- \"accept\" --> ST_done\n  ST_validating -- \"jump_to [slots.stage == 'done\u2026]\" --> ST_done\n  ST_validating -- \"accept [world.validate_artif\u2026]\" --> ST_implementing\n  ST_validating -- \"restart_from [slots.stage == 'impl\u2026]\" --> ST_implementing\n  ST_validating -- \"accept [world.validate_artif\u2026]\" --> ST_proposing\n  ST_validating -- \"restart_from\" --> ST_proposing\n  ST_validating -- \"restart_from [slots.stage == 'prop\u2026]\" --> ST_proposing\n  ST_validating -- \"restart_from [slots.stage == 'repr\u2026]\" --> ST_reproducing\n  ST_validating -- \"restart_from [slots.stage == 'test\u2026]\" --> ST_testing\n  ST_validating -- \"accept [world.validate_artif\u2026]\" --> ST_validating\n  ST_validating -- \"look\" --> ST_validating\n  ST_validating -- \"refine\" --> ST_validating\n\n  classDef input  fill:#eef,stroke:#446,stroke-width:1.5px\n  classDef room   fill:#fff,stroke:#357,stroke-width:1.5px\n  classDef work   fill:#f7f7fa,stroke:#888\n  classDef llm    fill:#f0e6ff,stroke:#6a3eb5,stroke-width:2px,color:#3a2270\n  classDef shell  fill:#fef6e4,stroke:#a85,stroke-width:1.5px\n  classDef store  fill:#eef5fb,stroke:#369,stroke-width:1px\n  classDef cache  fill:#fff6e0,stroke:#a86,stroke-width:1.5px\n  classDef err    fill:#fff5f5,stroke:#c66,stroke-width:1px,stroke-dasharray:4 3\n  classDef next   fill:#e8f5e9,stroke:#272,stroke-width:1.5px\n  classDef note   fill:#fffbe6,stroke:#a90,stroke-width:1px,stroke-dasharray:2 2,color:#553\n",
