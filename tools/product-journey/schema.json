{
  "version": 1,
  "artifact_root": ".artifacts/product-journey/<run-id>",
  "stages": [
    "discover_product",
    "follow_tutorial",
    "onboard_project",
    "plan_project_work",
    "fix_bug",
    "file_product_issue",
    "score_and_report"
  ],
  "run_result": {
    "required": ["run_id", "created_at", "mode", "project", "persona", "stages", "scenarios", "artifacts"],
    "artifacts": ["run.json", "journey.md", "metrics.json", "bugs.json", "findings.json", "evidence.json", "scenarios.json", "review.json", "deck.slidey.json"]
  },
  "matrix_result": {
    "required": ["matrix_id", "created_at", "seed", "target_count", "assignment_count", "scenario_count", "targets", "assignments", "artifacts"],
    "artifacts": ["matrix.json", "matrix.md", "deck.slidey.json"],
    "target_count": 10
  },
  "stage_statuses": ["planned", "ready", "captured", "cached_validated", "validated", "blocked", "error"],
  "scenario": {
    "required": ["id", "label", "stage", "task", "primary_story", "required_mcp", "evidence", "success_criteria"]
  },
  "evidence_statuses": ["missing", "captured", "validated", "rejected"],
  "finding_kinds": ["strength", "weakness", "issue", "fix"],
  "review_statuses": ["not_reviewed", "needs_evidence", "ready"],
  "review_check_statuses": ["pass", "warn", "fail"],
  "demo_seed": {
    "evidence_items": 6,
    "findings": 4
  }
}
