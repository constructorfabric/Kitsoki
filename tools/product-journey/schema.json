{
  "version": 1,
  "artifact_root": ".artifacts/product-journey/<run-id>",
  "stages": [
    "discover_product",
    "follow_tutorial",
    "onboard_project",
    "plan_project_work",
    "fix_bug",
    "file_product_issue",
    "score_and_report"
  ],
  "run_result": {
    "required": ["run_id", "created_at", "mode", "project", "persona", "stages", "scenarios", "artifacts"],
    "artifacts": ["run.json", "journey.md", "metrics.json", "bugs.json", "findings.json", "evidence.json", "scenarios.json", "execution-plan.json", "execution-plan.md", "agent-brief.json", "agent-brief.md", "review.json", "deck.slidey.json"]
  },
  "agent_brief": {
    "required": ["run_id", "project", "persona", "mission", "persona_contract", "operating_rules", "scenario_order", "missing_evidence", "finalize_commands"],
    "scenario_required": ["id", "label", "task", "primary_story", "mcp_tools", "success_criteria", "evidence"]
  },
  "execution_plan": {
    "required": ["run_id", "project", "persona", "summary", "steps", "finalize_commands"],
    "step_required": ["scenario", "primary_story", "mcp_steps", "evidence", "success_criteria", "attach_commands"]
  },
  "matrix_result": {
    "required": ["matrix_id", "created_at", "seed", "target_count", "assignment_count", "scenario_count", "targets", "assignments", "artifacts"],
    "artifacts": ["matrix.json", "matrix.md", "deck.slidey.json"],
    "target_count": 10
  },
  "matrix_rollup": {
    "required": ["matrix_id", "summary", "runs", "artifacts"],
    "artifacts": ["rollup.json", "rollup.md", "rollup.slidey.json"]
  },
  "stage_statuses": ["planned", "ready", "captured", "cached_validated", "validated", "blocked", "error"],
  "scenario": {
    "required": ["id", "label", "stage", "task", "primary_story", "required_mcp", "evidence", "success_criteria"]
  },
  "evidence_statuses": ["missing", "captured", "validated", "rejected"],
  "finding_kinds": ["strength", "weakness", "issue", "fix"],
  "review_statuses": ["not_reviewed", "needs_evidence", "ready"],
  "review_check_statuses": ["pass", "warn", "fail"],
  "demo_seed": {
    "evidence_items": 6,
    "findings": 4
  }
}
